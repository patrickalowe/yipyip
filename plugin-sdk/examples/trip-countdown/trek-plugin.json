{
  "id": "trip-countdown",
  "name": "Trip Countdown",
  "version": "1.0.0",
  "apiVersion": 1,
  "author": "TREK",
  "description": "A dashboard widget counting down the days to your next trip.",
  "homepage": "https://github.com/mauriceboe/TREK",
  "license": "MIT",
  "icon": "CalendarClock",
  "type": "widget",
  "trek": ">=3.2.0 <4.0.0",
  "nativeModules": false,
  "permissions": ["db:read:trips"],
  "capabilities": {
    "widget": { "title": "Trip Countdown", "defaultSize": "small" }
  },
  "routes": [
    { "method": "GET", "path": "/next", "auth": true }
  ]
}
